<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_biblioteca_prestamo_list" model="ir.ui.view">
        <field name="name">biblioteca.prestamo.list</field>
        <field name="model">biblioteca.prestamo</field>
        <field name="arch" type="xml">
            <list string="Libros Prestados">
                <field name="lector_id"/>
                <field name="cedula_rel"/>
                <field name="libro_id"/>
                <field name="categoria_rel"/>
                <field name="dia_prestados_rel"/>
                <field name="multa_total"/>
            </list>
        </field>
    </record>

    <record id="view_biblioteca_prestamo_form" model="ir.ui.view">
        <field name="name">biblioteca.prestamo.form</field>
        <field name="model">biblioteca.prestamo</field>
        <field name="arch" type="xml">
            <form string="Libro a Pedir">
                <sheet>
                    <group>
                        <group string="Datos del Lector">
                            <field name="lector_id"/>
                            <field name="cedula_rel"/>
                            <field name="limite_prestamos_rel"/>
                            <field name="sede_rel"/>
                        </group>
                        <group string="Datos de Libro">
                            <field name="libro_id"/>
                            <field name="categoria_rel"/>
                            <field name="dia_prestados_rel"/>
                            <field name="multa_diaria_rel"/>
                        </group>
                        <group string="Datos Del prestamo">
                            <field name="dias_usados"/>
                            <field name="dias_atrasados"/>
                            <field name="multa_total"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biblioteca_prestamos" model="ir.actions.act_window">
        <field name="name">Prestamos</field>
        <field name="res_model">biblioteca.prestamo</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_biblioteca_prestamos"
              name="Prestamos"
              parent="biblioteca_base.menu_biblioteca_root"
              action="action_biblioteca_prestamos"
              sequence="40"/>
</odoo>
