<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_proveedor_list" model="ir.ui.view">
        <field name="name">zapatos.proveedor.list</field>
        <field name="model">zapatos.proveedor</field>
        <field name="arch" type="xml">
            <list string="Proveedores">
                <field name="name"/>
                <field name="telefono"/>
                <field name="email"/>
            </list>
        </field>
    </record>

   
    <record id="view_proveedor_form" model="ir.ui.view">
        <field name="name">zapatos.proveedor.form</field>
        <field name="model">zapatos.proveedor</field>
        <field name="arch" type="xml">
            <form string="Proveedor">

                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre del proveedor"/>
                        </h1>
                    </div>

                    <group>

                        <group string="Información de Contacto">
                            <field name="telefono"/>
                            <field name="email"/>
                        </group>

                        <group string="Ubicación">
                            <field name="direccion"/>
                        </group>

                    </group>

                    <separator string="Información General"/>

                    <group>
                        <div class="text-muted">
                            Registre aquí la información de contacto del proveedor para asociarlo posteriormente con los zapatos.
                        </div>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

    
    <record id="action_proveedores" model="ir.actions.act_window">
        <field name="name">Proveedores</field>
        <field name="res_model">zapatos.proveedor</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>