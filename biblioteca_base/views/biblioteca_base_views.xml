<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <menuitem id="menu_biblioteca_root" name="Biblioteca" sequence="10"/>

    <record id="view_biblioteca_sede_list" model="ir.ui.view">
        <field name="name">biblioteca.sede.list</field>
        <field name="model">biblioteca.sede</field>
        <field name="arch" type="xml">
            <list string="Sedes de Biblioteca">
                <field name="codigo"/>
                <field name="name"/>
                <field name="ciudad"/>
                <field name="direccion"/>
            </list>
        </field>
    </record>

    <record id="view_biblioteca_sede_form" model="ir.ui.view">
        <field name="name">biblioteca.sede.form</field>
        <field name="model">biblioteca.sede</field>
        <field name="arch" type="xml">
            <form string="Sede de Biblioteca">
                <sheet>
                    <group string="Datos de la Sede">
                        <field name="codigo"/>
                        <field name="name"/>
                        <field name="ciudad"/>
                        <field name="direccion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biblioteca_sede" model="ir.actions.act_window">
        <field name="name">Sedes</field>
        <field name="res_model">biblioteca.sede</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_biblioteca_sedes" name="Sedes" parent="menu_biblioteca_root" action="action_biblioteca_sede" sequence="10"/>

    <record id="view_biblioteca_categoria_list" model="ir.ui.view">
        <field name="name">biblioteca.categoria.list</field>
        <field name="model">biblioteca.categoria</field>
        <field name="arch" type="xml">
            <list string="Categorías">
                <field name="name"/>
                <field name="descripcion"/>
            </list>
        </field>
    </record>

    <record id="view_biblioteca_categoria_form" model="ir.ui.view">
        <field name="name">biblioteca.categoria.form</field>
        <field name="model">biblioteca.categoria</field>
        <field name="arch" type="xml">
            <form string="Categoría">
                <sheet>
                    <group string="Datos de la Categoría">
                        <field name="name"/>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biblioteca_categoria" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">biblioteca.categoria</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_biblioteca_categorias" name="Categorías" parent="menu_biblioteca_root" action="action_biblioteca_categoria" sequence="20"/>

    <record id="view_biblioteca_libro_list" model="ir.ui.view">
        <field name="name">biblioteca.libro.list</field>
        <field name="model">biblioteca.libro</field>
        <field name="arch" type="xml">
            <list string="Libros">
                <field name="codigo"/>
                <field name="titulo"/>
                <field name="autor"/>
                <field name="categoria_id"/>
                <field name="dias_prestamo"/>
                <field name="multa_diaria"/>
                <field name="disponible"/>
            </list>
        </field>
    </record>

    <record id="view_biblioteca_libro_form" model="ir.ui.view">
        <field name="name">biblioteca.libro.form</field>
        <field name="model">biblioteca.libro</field>
        <field name="arch" type="xml">
            <form string="Libro">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="titulo" placeholder="Título del libro"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Datos del Libro">
                            <field name="codigo"/>
                            <field name="autor"/>
                            <field name="categoria_id"/>
                        </group>
                        <group string="Condiciones de Préstamo">
                            <field name="dias_prestamo"/>
                            <field name="multa_diaria"/>
                            <field name="disponible"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biblioteca_libro" model="ir.actions.act_window">
        <field name="name">Libros</field>
        <field name="res_model">biblioteca.libro</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_biblioteca_libros" name="Libros" parent="menu_biblioteca_root" action="action_biblioteca_libro" sequence="30"/>
</odoo>
