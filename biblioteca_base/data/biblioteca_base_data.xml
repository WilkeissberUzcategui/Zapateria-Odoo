<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sede_central" model="biblioteca.sede">
        <field name="codigo">SED-001</field>
        <field name="name">Biblioteca Central</field>
        <field name="ciudad">Quito</field>
        <field name="direccion">Av. Principal y Los Pinos</field>
    </record>

    <record id="sede_norte" model="biblioteca.sede">
        <field name="codigo">SED-002</field>
        <field name="name">Biblioteca Norte</field>
        <field name="ciudad">Quito</field>
        <field name="direccion">Av. Amazonas y Naciones Unidas</field>
    </record>

    <record id="categoria_literatura" model="biblioteca.categoria">
        <field name="name">Literatura</field>
        <field name="descripcion">Novelas, cuentos y obras literarias.</field>
    </record>

    <record id="categoria_tecnologia" model="biblioteca.categoria">
        <field name="name">Tecnología</field>
        <field name="descripcion">Libros de programación, redes y sistemas.</field>
    </record>

    <record id="categoria_ciencias" model="biblioteca.categoria">
        <field name="name">Ciencias</field>
        <field name="descripcion">Libros de matemática, física, química y biología.</field>
    </record>

    <record id="libro_001" model="biblioteca.libro">
        <field name="codigo">LIB-001</field>
        <field name="titulo">Introducción a Python</field>
        <field name="autor">Ana Pérez</field>
        <field name="categoria_id" ref="categoria_tecnologia"/>
        <field name="dias_prestamo">7</field>
        <field name="multa_diaria">0.50</field>
        <field name="disponible">1</field>
    </record>

    <record id="libro_002" model="biblioteca.libro">
        <field name="codigo">LIB-002</field>
        <field name="titulo">Matemática Básica Aplicada</field>
        <field name="autor">Carlos Ruiz</field>
        <field name="categoria_id" ref="categoria_ciencias"/>
        <field name="dias_prestamo">10</field>
        <field name="multa_diaria">0.40</field>
        <field name="disponible">1</field>
    </record>

    <record id="libro_003" model="biblioteca.libro">
        <field name="codigo">LIB-003</field>
        <field name="titulo">Cuentos Andinos</field>
        <field name="autor">María León</field>
        <field name="categoria_id" ref="categoria_literatura"/>
        <field name="dias_prestamo">5</field>
        <field name="multa_diaria">0.30</field>
        <field name="disponible">1</field>
    </record>
</odoo>
